///|
struct Style {
  size_plan : SizePlan // The plan to calculate the size of this entity in the UI world
  flex : Flex // The flexing direction for its child entities
  h_padding : Double // The flexing paddings
  v_padding : Double
  h_offset : Double // The offset of this entity respective to its parent
  v_offset : Double
}

///|
pub fn Style::new(
  size_plan? : SizePlan = SizePlan::FromSprite,
  flex? : Flex = Flex::Overlap,
  h_padding? : Double = 0.0,
  v_padding? : Double = 0.0,
  h_offset? : Double = 0.0,
  v_offset? : Double = 0.0,
) -> Style {
  { size_plan, flex, h_padding, v_padding, h_offset, v_offset }
}

///|
pub let styles : Map[@entity.Entity, Style] = Map::new()

///|
/// Cached layout sizes generated by `style_system`.
pub let layout_sizes : Map[@entity.Entity, @math.Vec2D] = Map::new()

///|
pub fn style_system(_delta : Double) -> Unit {
  layout_sizes.clear()
  sync_screen_roots()
  for root in @entity.get_roots() {
    guard root.is_alive() else { continue }
    layout_styled_subtree(root)
  }
}

///|
fn sync_screen_roots() -> Unit {
  if styles.get(screen_root) is Some(style) {
    styles.set(screen_root, {
      ..style,
      size_plan: Sized(@system.get_viewport_size()),
    })
  }
  if styles.get(screen_pixel_root) is Some(style) {
    styles.set(screen_pixel_root, {
      ..style,
      size_plan: Sized(@system.get_screen_size()),
    })
  }
}

///|
fn layout_styled_subtree(root : @entity.Entity) -> Unit {
  let taffy : @moon_taffy.TaffyTree[@entity.Entity] = @moon_taffy.TaffyTree::new()
  let node_entities : Array[@entity.Entity] = []
  let root_node = build_taffy_node(
    taffy,
    node_entities,
    root,
    @math.Vec2D::zero(),
    None,
  )
  guard root_node is Some(root_node) else { return }
  let compute_result : Result[Unit, @moon_taffy.TaffyError] = try? taffy.compute_layout(
    root_node,
    @moon_taffy.Size::max_content(),
  )
  match compute_result {
    Ok(_) => ()
    Err(_) => return
  }
  for node_id, entity in node_entities {
    let layout_result : Result[@moon_taffy.Layout, @moon_taffy.TaffyError] = try? taffy.layout(
      node_id,
    )
    match layout_result {
      Ok(layout) => {
        let size = @math.Vec2D(layout.size.width, layout.size.height)
        layout_sizes.set(entity, size)
        if entity.is_child() {
          entity.set_offset(@math.Vec2D(layout.location.x, layout.location.y))
        }
      }
      Err(_) => continue
    }
  }
}

///|
fn build_taffy_node(
  taffy : @moon_taffy.TaffyTree[@entity.Entity],
  node_entities : Array[@entity.Entity],
  entity : @entity.Entity,
  parent_overlap_shift : @math.Vec2D,
  parent_flex : Flex?,
) -> Int? {
  guard styles.get(entity) is Some(style) else { return None }
  let next_parent_overlap_shift = match style.flex {
    Overlap => @math.Vec2D(style.h_padding, style.v_padding)
    _ => @math.Vec2D::zero()
  }
  let child_node_ids : Array[Int] = []
  for child in entity.get_children() {
    if build_taffy_node(
        taffy,
        node_entities,
        child,
        next_parent_overlap_shift,
        Some(style.flex),
      )
      is Some(child_node_id) {
      child_node_ids.push(child_node_id)
    }
  }
  let taffy_style = style_to_taffy_style(
    entity, style, parent_overlap_shift, parent_flex,
  )
  let node_id = taffy.new_leaf_with_context(taffy_style, entity)
  if child_node_ids.length() > 0 {
    let set_children_result : Result[Unit, @moon_taffy.TaffyError] = try? taffy.set_children(
      node_id, child_node_ids,
    )
    match set_children_result {
      Ok(_) => ()
      Err(_) => return None
    }
  }
  node_entities.push(entity)
  Some(node_id)
}

///|
fn style_to_taffy_style(
  entity : @entity.Entity,
  style : Style,
  parent_overlap_shift : @math.Vec2D,
  parent_flex : Flex?,
) -> @moon_taffy.Style {
  let mut taffy_style = @moon_taffy.Style::default()
  taffy_style = match style.flex {
    Horizontal =>
      taffy_style
      .with_display(@moon_taffy.display_flex())
      .with_flex_direction(@moon_taffy.flex_direction_row())
      .with_padding(
        @moon_taffy.Rect::new(
          left=@moon_taffy.length(style.h_padding),
          right=@moon_taffy.length(0.0),
          top=@moon_taffy.length(style.v_padding),
          bottom=@moon_taffy.length(0.0),
        ),
      )
      .with_gap(
        @moon_taffy.Size::new(
          width=@moon_taffy.length(style.h_padding),
          height=@moon_taffy.length(0.0),
        ),
      )
    Vertical =>
      taffy_style
      .with_display(@moon_taffy.display_flex())
      .with_flex_direction(@moon_taffy.flex_direction_column())
      .with_padding(
        @moon_taffy.Rect::new(
          left=@moon_taffy.length(style.h_padding),
          right=@moon_taffy.length(0.0),
          top=@moon_taffy.length(style.v_padding),
          bottom=@moon_taffy.length(0.0),
        ),
      )
      .with_gap(
        @moon_taffy.Size::new(
          width=@moon_taffy.length(0.0),
          height=@moon_taffy.length(style.v_padding),
        ),
      )
    Overlap => taffy_style.with_display(@moon_taffy.display_grid())
  }
  taffy_style = match resolve_plan_size(entity, style) {
    Some(size) =>
      taffy_style.with_size(
        @moon_taffy.Size::new(
          width=@moon_taffy.length(non_negative(size[X])),
          height=@moon_taffy.length(non_negative(size[Y])),
        ),
      )
    None => taffy_style
  }
  taffy_style = match parent_flex {
    Some(Overlap) =>
      taffy_style.with_grid_row_start(1).with_grid_column_start(1)
    _ => taffy_style
  }
  let offset_x = style.h_offset + parent_overlap_shift[X]
  let offset_y = style.v_offset + parent_overlap_shift[Y]
  if offset_x == 0.0 && offset_y == 0.0 {
    taffy_style
  } else {
    taffy_style
    .with_position(@moon_taffy.position_relative())
    .with_inset(
      @moon_taffy.Rect::new(
        left=@moon_taffy.length(offset_x),
        right=@moon_taffy.auto(),
        top=@moon_taffy.length(offset_y),
        bottom=@moon_taffy.auto(),
      ),
    )
  }
}

///|
fn resolve_plan_size(entity : @entity.Entity, style : Style) -> @math.Vec2D? {
  match style.size_plan {
    Sized(s) => Some(s)
    FromSprite =>
      @sprite.sprites
      .get(entity)
      .map(sprite => {
        match sprite.sprite_type {
          Picture(picture) => picture.transform.apply_to_vec2d(picture.size)
          Text(_text) => default_text_size()
          Animation(anime, ..) =>
            anime.transform.apply_to_vec2d(anime.frames[0].size)
          ColorRect(rect) => rect.size
          ColorCircle(circle) =>
            @math.Vec2D(circle.radius * 2, circle.radius * 2)
        }
      })
    FromChildren => None
    FromShape =>
      @collision.shapes
      .get(entity)
      .map(shape => {
        match shape {
          Rect(size~, ..) => size
        }
      })
  }
}

///|
fn non_negative(value : Double) -> Double {
  if value < 0.0 {
    0.0
  } else {
    value
  }
}

///|
/// Fallback text size used before real text metrics are wired to layout.
fn default_text_size() -> @math.Vec2D {
  @math.Vec2D(48, 24)
}
